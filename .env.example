# Local development only. Production refuses to start until the required values
# below are configured in the hosting platform's secret manager.
NODE_ENV=development
PORT=4000
PUBLIC_BASE_URL=http://localhost:4000
DATABASE_URL=postgres://agensy:change-me@localhost:5432/agensy
# Set true only when the database endpoint requires TLS.
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
CORS_ORIGINS=http://localhost:5173
ADMIN_USERNAME=operator
ADMIN_PASSWORD=replace-with-a-strong-unique-password
JEKO_PAYMENT_URL=https://checkout.jeko.africa
JEKO_WEBHOOK_SECRET=replace-with-the-jeko-webhook-secret
FNE_API_URL=
FNE_API_TOKEN=
WHATSAPP_WEBHOOK_URL=
# Demo only: every user receives the fixed OTP 0000 and WhatsApp/UltraMsg sends are disabled.
DEMO_OTP=true
# Public Mapbox token used by the mobile address search. Configure it in EAS
# environment variables for production builds; never put a secret token here.
EXPO_PUBLIC_MAPBOX_ACCESS_TOKEN=
