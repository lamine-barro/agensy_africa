{
  "name": "@agensy/api",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=.env --watch src/server.js",
    "start": "node --env-file-if-exists=.env src/server.js",
    "test": "node --test",
    "migrate": "psql \"$DATABASE_URL\" -f migrations/001_initial.sql && psql \"$DATABASE_URL\" -f migrations/002_catalog_and_order_workflow.sql && psql \"$DATABASE_URL\" -f migrations/003_manual_invoice_workflow.sql",
    "seed:catalog": "node --env-file-if-exists=.env src/seed-catalog.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "pg": "^8.22.0"
  }
}
